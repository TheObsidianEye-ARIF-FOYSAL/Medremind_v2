rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Doc ID is the user's phone number; custom auth tokens are minted with
    // uid == phone (see functions/index.js), so a signed-in client can only
    // ever read its own document. passwordHash is never exposed: writes only
    // happen via the Admin SDK inside Cloud Functions, which bypasses rules.
    match /users/{phone} {
      allow read: if request.auth != null && request.auth.uid == phone;
      allow write: if false;
    }
  }
}
